{
    "name": "zeewolf-sar",
    "private": true,
    "version": "23.3",
    "type": "module",
    "main": "workbench/dist/main/index.cjs",
    "scripts": {
        "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite\" \"node workbench/build.mjs && electron .\"",
        "dev:vite": "vite",
        "postinstall": "node workbench/rename-electron.mjs",
        "workbench:build": "node workbench/build.mjs",
        "build": "vite build",
        "preview": "vite preview",
        "predeploy": "npm run build:game",
        "deploy": "gh-pages -d dist/",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@types/node": "^25.3.0",
        "@vitest/coverage-v8": "^4.1.0",
        "concurrently": "^9.0.0",
        "electron": "^35.7.5",
        "gh-pages": "^6.3.0",
        "monaco-editor": "^0.52.0",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.1.0"
    }
}
